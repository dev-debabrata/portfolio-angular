{
  "version": 2,
  "builds": [
    {
      "src": "dist/frontend/server/server.mjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/(.*\\.(js|css|ico|png|jpg|svg|woff2|woff|ttf|json|woff2))",
      "dest": "/dist/frontend/browser/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/dist/frontend/server/server.mjs"
    }
  ]
}
